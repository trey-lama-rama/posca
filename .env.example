# Headless CRM Secrets
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# GOG CLI (Gmail/Calendar access)
GOG_KEYRING_PASSWORD=

# OpenAI (for AI enrichment and extraction)
OPENAI_API_KEY=

# iCloud Contacts (app-specific password)
# Generate at https://appleid.apple.com > Sign-In and Security > App-Specific Passwords
ICLOUD_APP_PASSWORD=

# Supabase (optional — for cloud sync)
SUPABASE_URL=
SUPABASE_KEY=

# Proxycurl (optional — for LinkedIn enrichment)
PROXYCURL_API_KEY=

# ro.am (optional — for meeting transcript ingestion)
ROAM_API_KEY=

# Zoom (optional — for meeting recording ingestion)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
